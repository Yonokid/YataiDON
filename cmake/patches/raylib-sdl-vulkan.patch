+void InitVulkanSurface(void)
+{
+    VkSurfaceKHR surface = VK_NULL_HANDLE;
+#ifdef USING_SDL3_PROJECT
+    bool ok = SDL_Vulkan_CreateSurface(platform.window, rlvkGetInstance(), NULL, &surface);
+#else
+    bool ok = (SDL_Vulkan_CreateSurface(platform.window, rlvkGetInstance(), &surface) == SDL_TRUE);
+#endif
+    if (ok) rlvkAttachSurface(surface);
+    else TRACELOG(LOG_WARNING, "VKRL: SDL_Vulkan_CreateSurface failed: %s", SDL_GetError());
+}
