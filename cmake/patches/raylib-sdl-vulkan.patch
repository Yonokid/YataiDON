 RLVKAPI void rlvkSetMsaaSamples(int samples);       // Set MSAA sample count, call BEFORE rlvkAttachSurface (FLAG_MSAA_4X_HINT)
+RLVKAPI void rlvkSetVsync(bool enabled);            // Set vsync-locked (FIFO) vs uncapped presentation, call BEFORE rlvkAttachSurface (FLAG_VSYNC_HINT)
