diff --git a/cmake/LibraryConfigurations.cmake b/cmake/LibraryConfigurations.cmake
index 262150b..60a1589 100644
--- a/cmake/LibraryConfigurations.cmake
+++ b/cmake/LibraryConfigurations.cmake
@@ -259,6 +259,14 @@ if (NOT GRAPHICS)
     set(GRAPHICS "GRAPHICS_API_OPENGL_33")
 endif ()
 
+# rlvk.h calls vkCreateInstance/vkCreateSwapchainKHR/... directly (link-time symbols, not
+# resolved through vkGetInstanceProcAddr), so the Vulkan loader must be linked explicitly -
+# nothing else in this file pulls it in for either the GLFW or SDL desktop backend.
+if ("${GRAPHICS}" MATCHES "GRAPHICS_API_VULKAN")
+    find_package(Vulkan REQUIRED)
+    set(LIBS_PRIVATE ${LIBS_PRIVATE} Vulkan::Vulkan)
+endif ()
+
 set(LIBS_PRIVATE ${LIBS_PRIVATE} ${OPENAL_LIBRARY})
 
 if (SUPPORT_MODULE_RAUDIO AND UNIX AND NOT APPLE)
