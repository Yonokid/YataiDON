 //----------------------------------------------------------------------------------
 // Defines and Macros
 //----------------------------------------------------------------------------------
@@ -1315,10 +1332,28 @@ void DisableCursor(void)
     CORE.Input.Mouse.cursorLocked = true;
 }
 
+#if defined(GRAPHICS_API_VULKAN_14)
+// Create the Vulkan window surface + swapchain. Called from InitWindow right after rlglInit (which
+// creates the instance), so the swapchain exists before the first frame is rendered/captured.
+void InitVulkanSurface(void)
+{
+    VkSurfaceKHR surface = VK_NULL_HANDLE;
+#ifdef USING_SDL3_PROJECT
+    bool ok = SDL_Vulkan_CreateSurface(platform.window, rlvkGetInstance(), NULL, &surface);
+#else
+    bool ok = (SDL_Vulkan_CreateSurface(platform.window, rlvkGetInstance(), &surface) == SDL_TRUE);
+#endif
+    if (ok) rlvkAttachSurface(surface);
+    else TRACELOG(LOG_WARNING, "VKRL: SDL_Vulkan_CreateSurface failed: %s", SDL_GetError());
+}
+#endif
+
 // Swap back buffer with front buffer (screen drawing)
 void SwapScreenBuffer(void)
 {
-#if defined(GRAPHICS_API_OPENGL_SOFTWARE)
+#if defined(GRAPHICS_API_VULKAN_14)
+    rlvkPresent();
+#elif defined(GRAPHICS_API_OPENGL_SOFTWARE)
     // NOTE: Using a preprocessor condition here because rlCopyFramebuffer() is only declared for software rendering
     SDL_Surface *surface = SDL_GetWindowSurface(platform.window);
     rlCopyFramebuffer(0, 0, CORE.Window.render.width, CORE.Window.render.height, PIXELFORMAT_UNCOMPRESSED_R8G8B8A8, surface->pixels);
@@ -2049,6 +2084,12 @@ int InitPlatform(void)
 
     // NOTE: Some OpenGL context attributes must be set before window creation
 
+#if defined(GRAPHICS_API_VULKAN_14)
+    // No OpenGL context: the window just needs to be Vulkan-surface-capable.
+    // rlGetVersion() reports RL_OPENGL_43 as a compatibility shim under Vulkan, so it
+    // can't be used here to decide between GL/Vulkan/software the way it is below.
+    flags |= SDL_WINDOW_VULKAN;
+#else
     if (rlGetVersion() != RL_OPENGL_SOFTWARE)
     {
         // Add the flag telling the window to use an OpenGL context
@@ -2094,6 +2135,7 @@ int InitPlatform(void)
             SDL_GL_SetAttribute(SDL_GL_MULTISAMPLESAMPLES, 4);
         }
     }
+#endif  // !GRAPHICS_API_VULKAN_14
 
     // Init window
 #if defined(USING_VERSION_SDL3)
@@ -2111,13 +2153,19 @@ int InitPlatform(void)
     platform.window = SDL_CreateWindow(CORE.Window.title, SDL_WINDOWPOS_UNDEFINED, SDL_WINDOWPOS_UNDEFINED, CORE.Window.screen.width, CORE.Window.screen.height, flags);
 #endif
 
+#if !defined(GRAPHICS_API_VULKAN_14)
