-    // Benchmarking wants uncapped presentation: prefer IMMEDIATE (no sync), then MAILBOX.
+    // Benchmarking always wants uncapped presentation, regardless of FLAG_VSYNC_HINT/rlvkSetVsync.
+    bool wantUncappedPresent = true;
+#else
+    // rlvkSetVsync(false) (FLAG_VSYNC_HINT off) -> uncapped presentation.
+    bool wantUncappedPresent = !RLVK.vsyncEnabled;
+#endif
+    if (wantUncappedPresent)
     {
+        // Uncapped presentation: prefer IMMEDIATE (no sync), then MAILBOX.
         uint32_t pmCount = 0;
         vkGetPhysicalDeviceSurfacePresentModesKHR(RLVK.physicalDevice, surface, &pmCount, NULL);
         VkPresentModeKHR pms[16];
@@ -6034,7 +6051,6 @@
