+        #endif
+        char *slash = strrchr(exePath, '/');
+        if (slash)
+        {
+            strncpy(slash + 1, libName, (size_t)(&exePath[sizeof(exePath)] - (slash + 1)) - 1);
+            lib = dlopen(exePath, RTLD_NOW | RTLD_LOCAL);
+        }
+    }
+    if (!lib) return false;
