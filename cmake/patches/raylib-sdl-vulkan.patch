+#if defined(GRAPHICS_API_VULKAN_14)
+    if (platform.window != NULL)
+#else
     if ((platform.window != NULL) && ((rlGetVersion() == RL_OPENGL_SOFTWARE) || (platform.glContext != NULL)))
+#endif
     {
         CORE.Window.ready = true;
 
