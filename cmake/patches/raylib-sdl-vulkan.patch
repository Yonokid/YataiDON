+    // dlopen the runtime GLSL->SPIR-V compiler. Try the system search path first (covers a
+    // system libshaderc package, found via the loader/ldconfig cache), then fall back to a
+    // copy sitting next to the running executable (covers the no-system-package case; the
+    // project build copies shaderc_shared there for exactly this reason).
+    #if defined(__APPLE__)
+        static const char *libName = "libshaderc_shared.dylib";
+    #else
+        static const char *libName = "libshaderc_shared.so.1";
+    #endif
+    void *lib = dlopen(libName, RTLD_NOW | RTLD_LOCAL);
+    if (!lib)
+    {
+        char exePath[4096] = {0};
+        #if defined(__APPLE__)
+            uint32_t size = sizeof(exePath);
+            if (_NSGetExecutablePath(exePath, &size) != 0) exePath[0] = '\0';
+        #else
+            ssize_t n = readlink("/proc/self/exe", exePath, sizeof(exePath) - 1);
