@@ -5972,6 +5974,14 @@
     if (RLVK.msaaSamples > 1) TRACELOG(RL_LOG_INFO, "RLVK: MSAA x%d enabled (matches GL FLAG_MSAA_4X_HINT)", RLVK.msaaSamples);
 }
 
+// Set whether presentation is vsync-locked (FIFO) or uncapped, must be called before rlvkAttachSurface()
+void rlvkSetVsync(bool enabled)
+{
+    if (RLVK.swapchain) { TRACELOG(RL_LOG_WARNING, "RLVK: rlvkSetVsync must be called before the swapchain exists"); return; }
+    RLVK.vsyncEnabled = enabled;
+    if (!enabled) TRACELOG(RL_LOG_INFO, "RLVK: VSync disabled, requesting uncapped present mode (matches GL FLAG_VSYNC_HINT)");
+}
+
